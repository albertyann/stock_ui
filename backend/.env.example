# Copy this file to .env and fill in real values.
# Backend reads these server-side; the frontend never receives the API key.

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgrespwd@localhost:5432/stock_data

# AI / LLM configuration (required for the stock chat assistant)
AI_API_KEY=your-api-key-here
AI_MODEL=deepseek-v4-flash
AI_BASE_URL=https://api.deepseek.com
AI_TIMEOUT=120
